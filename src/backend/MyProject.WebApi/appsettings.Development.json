{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database={INIT_PROJECT_SLUG};Username=postgres;Password=DevPassword123!"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "Caching": {
    "Enabled": true,
    "DefaultExpiration": "00:10:00"
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 300,
      "Window": "00:00:10"
    },
    "Registration": {
      "PermitLimit": 50,
      "Window": "00:00:10"
    },
    "Auth": {
      "PermitLimit": 300,
      "Window": "00:00:10"
    },
    "Sensitive": {
      "PermitLimit": 300,
      "Window": "00:00:10"
    },
    "AdminMutations": {
      "PermitLimit": 300,
      "Window": "00:00:10"
    }
  },
  "Authentication": {
    "Jwt": {
      "Key": "ThisIsADevelopmentJwtSecretKeyThatIsLongEnoughForHMACSHA256Signing",
      "AccessTokenLifetime": "01:40:00"
    },
    "ExternalProviders": {
      "AllowedRedirectUris": [
        "http://localhost:{INIT_FRONTEND_PORT}/oauth/callback"
      ],
      "EncryptionKey": "ThisIsADevelopmentOnlyEncryptionKeyThatIsAtLeast32CharsLong!"
    }
  },
  "Email": {
    "Enabled": true,
    "FrontendBaseUrl": "http://localhost:{INIT_FRONTEND_PORT}",
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "UseSsl": false
    }
  },
  "Hosting": {
    "ForceHttps": false
  },
  "Captcha": {
    "SecretKey": "1x0000000000000000000000000000000AA"
  },
  "FileStorage": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "admin",
    "SecretKey": "DevPassword123!",
    "BucketName": "{INIT_PROJECT_SLUG}-files",
    "UseSSL": false
  },
  "Cors": {
    "AllowAllOrigins": true
  },
  "Seed": {
    "Users": [
      {
        "Email": "{INIT_SUPERUSER_EMAIL}",
        "Password": "{INIT_SUPERUSER_PASSWORD}",
        "Role": "Superuser"
      }
    ]
  }
}
